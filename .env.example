# Valkey
VALKEY_PORT=6379

# Gateway
GATEWAY_PORT=8080

# External services (running on host)
LLAMA_SERVER_ADDR=host.docker.internal:8081
LLAMA_API_KEY=
MUNINNDB_ADDR=host.docker.internal:8100
MUNINNDB_API_KEY=

# LLM Broker
SLOT_COUNT=4
PREEMPT_TIMEOUT_MS=5000

# Agents
HEARTBEAT_INTERVAL_MS=3000
INACTIVITY_TIMEOUT_S=300

# Context Manager
SYSTEM_PROMPT=You are a helpful assistant.
