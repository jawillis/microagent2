# Valkey
VALKEY_PORT=6379

# Gateway
GATEWAY_PORT=8080
# Gateway stitches a client-side-state replay (a /v1/responses call with no
# previous_response_id but multi-message input) into an existing session when
# the hash of the history prefix matches a prior turn's stored hash. Hash
# index entries expire after this many hours so abandoned conversations do
# not leak state forever. Active conversations refresh the TTL every turn.
SESSION_HASH_TTL_HOURS=24

# External services (running on host)
LLAMA_SERVER_ADDR=host.docker.internal:8081
LLAMA_API_KEY=

# Hindsight — memory substrate, runs in this docker-compose.
# HINDSIGHT_IMAGE is required: set it to the Hindsight container image you
# want to run (see https://github.com/vectorize-io/hindsight for current tags).
HINDSIGHT_IMAGE=
HINDSIGHT_API_KEY=
# LLM API key Hindsight presents to llm-proxy. llm-proxy ignores the value
# today, but Hindsight requires some non-empty value to start.
HINDSIGHT_LLM_API_KEY=sk-local
# Model name that Hindsight sends to the chat-completions endpoint. Must match
# a model the backing llama-server advertises.
HINDSIGHT_LLM_MODEL=unsloth
HINDSIGHT_MEM_LIMIT=2g
# Control Plane UI (browse http://localhost:9999) + direct API access
HINDSIGHT_CP_PORT=9999
HINDSIGHT_API_PORT=8888

# Memory service — fronts Hindsight for all consumers.
# HINDSIGHT_WEBHOOK_SECRET is the HMAC-SHA256 secret used to sign and verify
# webhook deliveries from Hindsight to memory-service. Required; both ends
# must agree on the same value.
HINDSIGHT_WEBHOOK_SECRET=
MEMORY_BANK_ID=microagent2

# LLM Broker
# SLOT_COUNT is the total number of llama-server KV slots available to the
# broker. It must equal the llama-server's configured slot count.
# AGENT_SLOT_COUNT + HINDSIGHT_SLOT_COUNT must be <= SLOT_COUNT. Agents are
# only ever assigned agent-class slots; llm-proxy (routing Hindsight's LLM
# calls) is only ever assigned hindsight-class slots.
SLOT_COUNT=6
AGENT_SLOT_COUNT=4
HINDSIGHT_SLOT_COUNT=2
PREEMPT_TIMEOUT_MS=5000
PROVISIONAL_TIMEOUT_MS=2000
SLOT_SNAPSHOT_INTERVAL_S=30

# LLM Proxy — OpenAI-compatible HTTP front that routes Hindsight's LLM calls
# through the broker's hindsight-class slots to preserve agent KV cache.
LLM_PROXY_IDENTITY=llm-proxy
LLM_PROXY_SLOT_TIMEOUT_MS=10000
LLM_PROXY_REQUEST_TIMEOUT_MS=300000

# Agents
HEARTBEAT_INTERVAL_MS=3000
INACTIVITY_TIMEOUT_S=300

# Context Manager
SYSTEM_PROMPT=You are a helpful assistant.

# Skills + Tools (main-agent)
# SKILLS_DIR is where SKILL.md files are scanned at startup.
# In docker-compose this is fixed to /app/skills (the mount point).
# Bare-metal runs: change via env if needed.
# SKILLS_DIR=./skills
TOOL_LOOP_MAX_ITER=10

# MCP integration (main-agent)
# Per-invocation timeout for MCP tool calls (seconds). Default 30.
# MCP_INVOKE_TIMEOUT_S=30
# MCP servers themselves are configured via the dashboard (Agents panel)
# or by writing a JSON array to the Valkey key `config:mcp:servers`.
