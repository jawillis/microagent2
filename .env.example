# Valkey
VALKEY_PORT=6379

# Gateway
GATEWAY_PORT=8080
# Gateway stitches a client-side-state replay (a /v1/responses call with no
# previous_response_id but multi-message input) into an existing session when
# the hash of the history prefix matches a prior turn's stored hash. Hash
# index entries expire after this many hours so abandoned conversations do
# not leak state forever. Active conversations refresh the TTL every turn.
SESSION_HASH_TTL_HOURS=24

# External services (running on host)
LLAMA_SERVER_ADDR=host.docker.internal:8081
LLAMA_API_KEY=
MUNINNDB_ADDR=host.docker.internal:8100
MUNINNDB_API_KEY=

# LLM Broker
SLOT_COUNT=4
PREEMPT_TIMEOUT_MS=5000
PROVISIONAL_TIMEOUT_MS=2000
SLOT_SNAPSHOT_INTERVAL_S=30

# Agents
HEARTBEAT_INTERVAL_MS=3000
INACTIVITY_TIMEOUT_S=300

# Context Manager
SYSTEM_PROMPT=You are a helpful assistant.
