# syntax=docker/dockerfile:1.7

# Build stage: compile the Go binary.
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/exec ./cmd/exec

# Runtime stage: Python + uv + headless Chromium for Playwright-using skills.
FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    LANG=C.UTF-8

# System deps: curl/jq/git are convenience tools skills routinely use;
# the rest is a curated Chromium runtime dep set for Playwright headless mode.
# We deliberately do NOT use `playwright install --with-deps`: its hardcoded
# Ubuntu 20.04 package list references fonts (ttf-unifont, ttf-ubuntu-font-family)
# that are no longer in Debian trixie.
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl jq git \
      libnss3 libnspr4 \
      libatk1.0-0 libatk-bridge2.0-0 libatspi2.0-0 \
      libcups2 libdbus-1-3 libdrm2 libgbm1 \
      libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
      libxext6 libx11-6 libx11-xcb1 libxcb1 libxcursor1 libxi6 libxtst6 \
      libpango-1.0-0 libcairo2 libasound2 \
      fonts-liberation xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Install uv (static binary).
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
    && mv /root/.local/bin/uv /usr/local/bin/uv \
    && chmod 0755 /usr/local/bin/uv

# Non-root runtime user. UID 1500 matches the compose tmpfs uid= option.
RUN groupadd --gid 1500 exec \
    && useradd --uid 1500 --gid 1500 --create-home --shell /bin/bash exec \
    && mkdir -p /skills /workspace /cache \
    && chown exec:exec /workspace /cache

# Pre-install Playwright + Chromium browser for webapp-testing-style skills.
# Cache the browser binary at a predictable shared location so per-skill
# venvs can reference it via PLAYWRIGHT_BROWSERS_PATH without reinstalling.
# --with-deps is intentionally omitted; we curate the apt packages above.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN uv pip install --system --no-cache playwright==1.47.0 \
    && python -m playwright install chromium \
    && chmod -R a+rX /opt/playwright-browsers

# Bring in the Go binary.
COPY --from=build /bin/exec /bin/exec

USER exec
EXPOSE 8085
ENTRYPOINT ["/bin/exec"]
