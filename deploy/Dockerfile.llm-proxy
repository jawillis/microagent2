FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/llm-proxy ./cmd/llm-proxy

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=build /bin/llm-proxy /bin/llm-proxy
EXPOSE 8082
ENTRYPOINT ["/bin/llm-proxy"]
