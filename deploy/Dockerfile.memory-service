FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/memory-service ./cmd/memory-service

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=build /bin/memory-service /bin/memory-service
COPY deploy/memory /etc/microagent2/memory
EXPOSE 8083
ENTRYPOINT ["/bin/memory-service"]
